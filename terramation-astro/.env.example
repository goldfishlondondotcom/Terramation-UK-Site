# ── Brevo (formerly Sendinblue) ──────────────────────────────────────────────
#
# Find these in: Brevo dashboard → Settings → SMTP & API → API Keys
#
# Full API key (server-side only — never commit the real value)
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The numeric ID of the Brevo contact list to subscribe people to.
# Find it in: Contacts → Lists → click your list → the ID is in the URL
BREVO_LIST_ID=3

# Optional: Brevo "double opt-in" template ID.
# Create one in: Campaigns → Transactional → Templates
# Leave empty to use single opt-in (not recommended for GDPR).
BREVO_DOI_TEMPLATE_ID=1

# The URL Brevo redirects to after the user confirms their email (double opt-in).
# Should be an absolute URL on your site, e.g. a /thank-you page.
BREVO_DOI_REDIRECT_URL=https://terramation.uk/thank-you/
