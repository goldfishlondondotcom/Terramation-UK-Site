---
interface PostCardData {
  title: string;
  description: string;
  pubDate: Date;
  featuredImage?: string;
}

interface Props {
  href: string;
  post: {
    data: PostCardData;
  };
  headingTag?: "h2" | "h3";
  linkLabel?: string;
}

const {
  href,
  post,
  headingTag = "h2",
  linkLabel = "Read article",
} = Astro.props;

const HeadingTag = headingTag;

function formatDate(date: Date) {
  return date.toLocaleDateString("en-GB", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
}
---

<a href={href} class="card">
  {post.data.featuredImage ? (
    <img
      src={post.data.featuredImage}
      alt={post.data.title}
      class="card__image"
      loading="lazy"
    />
  ) : (
    <div class="card__image--placeholder card__image" aria-hidden="true">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
        <polyline points="14 2 14 8 20 8"/>
        <line x1="16" y1="13" x2="8" y2="13"/>
        <line x1="16" y1="17" x2="8" y2="17"/>
        <line x1="10" y1="9" x2="8" y2="9"/>
      </svg>
    </div>
  )}

  <div class="card__body">
    <span class="card__eyebrow">Terramation UK</span>
    <HeadingTag class="card__title">{post.data.title}</HeadingTag>
    <p class="card__excerpt">{post.data.description}</p>
    <p class="card__meta">{formatDate(post.data.pubDate)}</p>
    <span class="card__link">{linkLabel} →</span>
  </div>
</a>
