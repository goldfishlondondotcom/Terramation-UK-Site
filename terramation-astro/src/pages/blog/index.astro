---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

function postUrl(post: (typeof posts)[number]) {
  const d = post.data.pubDate;
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, "0");
  const day = String(d.getDate()).padStart(2, "0");
  return `/${y}/${m}/${day}/${post.id}/`;
}

function formatDate(date: Date) {
  return date.toLocaleDateString("en-GB", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
}
---

<BaseLayout
  title="Blog — Terramation UK"
  description="News, insights and updates on human composting, terramation and sustainable funeral options in the UK."
>

  <!-- Page header -->
  <div class="page-header">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <span aria-current="page">Blog</span>
      </nav>
      <h1>News &amp; Insights</h1>
      <p class="page-header__sub">
        The latest updates on human composting, terramation legislation,
        and sustainable end-of-life choices in the UK.
      </p>
    </div>
  </div>

  <!-- Posts grid -->
  <section class="blog-listing">
    <div class="container">
      {posts.length === 0 ? (
        <p>No posts yet. Check back soon.</p>
      ) : (
        <div class="grid-3">
          {posts.map((post) => (
            <a href={postUrl(post)} class="card">
              <div class="card__image--placeholder card__image" aria-hidden="true">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
                  <polyline points="14 2 14 8 20 8"/>
                  <line x1="16" y1="13" x2="8" y2="13"/>
                  <line x1="16" y1="17" x2="8" y2="17"/>
                  <line x1="10" y1="9"  x2="8" y2="9"/>
                </svg>
              </div>
              <div class="card__body">
                <span class="card__eyebrow">Terramation UK</span>
                <h2 class="card__title">{post.data.title}</h2>
                <p class="card__excerpt">{post.data.description}</p>
                <p class="card__meta">{formatDate(post.data.pubDate)}</p>
                <span class="card__link">Read article →</span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

</BaseLayout>
