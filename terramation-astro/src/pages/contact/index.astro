---
import BaseLayout from "../../layouts/BaseLayout.astro";
import NewsletterForm from "../../components/NewsletterForm.astro";
---

<BaseLayout
  title="Contact | Terramation UK"
  description="Get in touch with Terramation UK — join the Close the Circle campaign, ask questions about human composting, or enquire about advertising."
>

  <!-- Page header -->
  <div class="page-header">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <span aria-current="page">Contact</span>
      </nav>
      <h1>Get in touch</h1>
      <p class="page-header__sub">
        Questions about terramation, the campaign, or advertising with us?
        We'd love to hear from you.
      </p>
    </div>
  </div>

  <!-- Contact content -->
  <section class="section">
    <div class="container">
      <div class="contact-grid">

        <!-- Info column -->
        <div class="contact-info">
          <div>
            <h2 style="margin-block-end:var(--space-4);">Close the Circle campaign</h2>
            <p>
              We're working to make human composting a legal end-of-life choice in the UK.
              Add your voice and help us push for change — every supporter makes a difference.
            </p>
          </div>

          <div class="contact-info__item">
            <span class="contact-info__icon" aria-hidden="true">✉️</span>
            <div>
              <span class="contact-info__label">Email us</span>
              <a href="mailto:info@terramation.uk" class="contact-info__value">
                info@terramation.uk
              </a>
            </div>
          </div>

          <div class="contact-info__item">
            <span class="contact-info__icon" aria-hidden="true">📢</span>
            <div>
              <span class="contact-info__label">Advertise with us</span>
              <p class="contact-info__value" style="margin:0;">
                Audiences are actively searching for sustainable funeral options.
                Get in touch to reach them with your services.
              </p>
            </div>
          </div>

          <div class="contact-info__item">
            <span class="contact-info__icon" aria-hidden="true">🌿</span>
            <div>
              <span class="contact-info__label">Our mission</span>
              <p class="contact-info__value" style="margin:0;">
                Terramation UK educates the public on human composting and campaigns
                for its legalisation in England and Wales.
              </p>
            </div>
          </div>
        </div>

        <!-- Form column -->
        <div>
          <h2 style="margin-block-end:var(--space-6);">Send us a message</h2>
          <form
            class="contact-form"
            method="POST"
            data-contact-form
          >
            <p class="visually-hidden">
              <label for="bot-field">
                Do not fill out this field if you're human
              </label>
              <input id="bot-field" name="bot-field" autocomplete="off" tabIndex={-1} />
            </p>

            <div class="form-field">
              <label for="name">Your name</label>
              <input type="text" id="name" name="name" autocomplete="name" required placeholder="Jane Smith" />
            </div>

            <div class="form-field">
              <label for="email">Email address</label>
              <input type="email" id="email" name="email" autocomplete="email" required placeholder="jane@example.com" />
            </div>

            <div class="form-field">
              <label for="subject">Subject</label>
              <input type="text" id="subject" name="subject" placeholder="Campaign / Enquiry / Advertising" />
            </div>

            <div class="form-field">
              <label for="message">Message</label>
              <textarea id="message" name="message" required placeholder="Tell us how we can help…"></textarea>
            </div>

            <div class="contact-form__consent">
              <label class="contact-form__checkbox-label">
                <input
                  type="checkbox"
                  name="marketingOptIn"
                  value="on"
                  class="contact-form__checkbox"
                />
                <span>
                  I would also like to receive email updates from Terramation UK.
                  If ticked, my details will be added to Brevo list 6. See our
                  <a href="/privacy-policy/"> privacy policy</a>.
                </span>
              </label>
            </div>

            <button type="submit" class="btn btn--primary">Send message</button>

            <div class="contact-form__status" role="status" aria-live="polite" hidden></div>
          </form>
          <p class="contact-form__note">
            Messages are emailed directly to <a href="mailto:info@terramation.uk">info@terramation.uk</a>.
            If you tick the opt-in box, you'll also be added to our campaign updates list.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Newsletter sign-up -->
  <section class="section section--dark">
    <div class="container" style="max-width:640px;">
      <NewsletterForm
        variant="stacked"
        heading="Join 100,000+ supporters"
        subtext="Our petition has already gathered over 100,000 signatures. Sign up to stay informed and find out how to take action."
        dark={true}
      />
    </div>
  </section>

</BaseLayout>

<script>
  const contactForm = document.querySelector<HTMLFormElement>("[data-contact-form]");
  const statusEl = contactForm?.querySelector<HTMLElement>(".contact-form__status");

  function showStatus(message: string, isError: boolean) {
    if (!statusEl) return;
    statusEl.textContent = message;
    statusEl.hidden = false;
    statusEl.className = `contact-form__status ${isError ? "contact-form__status--error" : "contact-form__status--success"}`;
  }

  contactForm?.addEventListener("submit", async (event: SubmitEvent) => {
    event.preventDefault();

    const form = event.currentTarget;
    const submitButton = form.querySelector("button[type='submit']");

    if (!(form instanceof HTMLFormElement) || !(submitButton instanceof HTMLButtonElement)) {
      return;
    }

    submitButton.disabled = true;
    submitButton.textContent = "Sending…";

    if (statusEl) {
      statusEl.hidden = true;
    }

    try {
      const response = await fetch("/api/contact/", {
        method: "POST",
        body: new FormData(form),
      });

      const data = await response.json() as { success: boolean; message: string };
      showStatus(data.message, !data.success);

      if (data.success) {
        form.reset();
      }
    } catch {
      showStatus("Something went wrong. Please try again or email info@terramation.uk.", true);
    } finally {
      submitButton.disabled = false;
      submitButton.textContent = "Send message";
    }
  });
</script>
