---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { featuredProvider, providerCategories } from "../../data/provider-directory";

const providerSplitIndex = Math.ceil(providerCategories.length / 2);
const topProviderCategories = providerCategories.slice(0, providerSplitIndex);
const bottomProviderCategories = providerCategories.slice(providerSplitIndex);
---

<BaseLayout
  title="Find Sustainable Funerals in the UK | Terramation UK"
  description="Explore sustainable funeral options in the UK, including natural burials, water cremation, human composting, and other lower-impact end-of-life choices."
>
  <div class="page-header">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <span aria-current="page">Find Sustainable Funerals</span>
      </nav>
      <h1>Find Sustainable Funerals</h1>
      <p class="page-header__sub">
        A practical guide to lower-impact funeral options and the providers or organisations currently associated with them.
      </p>
    </div>
  </div>

  <section class="section section--tinted">
    <div class="container">
      <div class="featured-provider">
        <div class="featured-provider__media">
          <div class="featured-provider__logo">
            {featuredProvider.logoImage ? (
              <img src={featuredProvider.logoImage} alt={featuredProvider.name} />
            ) : (
              <span>{featuredProvider.logoText ?? "Featured logo"}</span>
            )}
          </div>
        </div>

        <div class="featured-provider__content">
          <div class="featured-provider__meta">
            <span class="featured-provider__label">{featuredProvider.label}</span>
            <span class="featured-provider__sponsorship">{featuredProvider.sponsorship}</span>
          </div>
          <h2>{featuredProvider.name}</h2>
          <p class="featured-provider__category">{featuredProvider.category}</p>
          <p class="featured-provider__summary">{featuredProvider.summary}</p>
          <ul class="featured-provider__list">
            {featuredProvider.highlights.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <div class="featured-provider__actions">
            <a href={featuredProvider.href} class="btn btn--earth">{featuredProvider.cta}</a>
            <a href="/advertise/" class="btn btn--outline featured-provider__secondary">View advertising options</a>
          </div>
        </div>
      </div>

      <div class="directory-intro directory-intro--compact">
        <div class="directory-intro__lead">
          <p class="directory-intro__eyebrow">At a glance</p>
          <h2>Compare what is available now and what still needs legal reform.</h2>
        </div>

        <div class="directory-intro__panels">
          <div class="directory-intro__panel directory-intro__panel--available">
            <span class="directory-intro__label">Already available</span>
            <p>Natural burial and some greener cremation-related options can already be researched in the UK.</p>
          </div>
          <div class="directory-intro__panel directory-intro__panel--developing">
            <span class="directory-intro__label">Still developing</span>
            <p>Where a method is not yet available in the UK, we mark that clearly so visitors can compare with confidence.</p>
          </div>
        </div>
      </div>

      <div class="provider-directory">
        {topProviderCategories.map((option) => (
          <article class="provider-card">
            <div class="provider-card__header">
              <div>
                <p class="provider-card__eyebrow">Sustainable option</p>
                <h2>{option.title}</h2>
              </div>
              <span class="provider-card__status">{option.status}</span>
            </div>

            <p class="provider-card__summary">{option.summary}</p>
            <p class="provider-card__cost">{option.estimatedCost}</p>

            {option.providers.length > 0 ? (
              <div class="provider-card__providers">
                <h3>Providers and organisations</h3>
                <ul class="provider-list">
                  {option.providers.map((provider) => (
                    <li class="provider-list__item">
                      <div class="provider-list__topline">
                        <div class="provider-list__title-wrap">
                          {provider.sponsored && <span class="provider-list__badge">Sponsored</span>}
                          <a href={provider.href} target="_blank" rel="noopener noreferrer" class="provider-list__title">
                            {provider.name}
                          </a>
                        </div>
                        <a
                          href={provider.href}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="btn btn--primary provider-list__button"
                        >
                          Visit website
                        </a>
                      </div>
                      <p>{provider.note}</p>
                    </li>
                  ))}
                </ul>
              </div>
            ) : (
              <div class="provider-card__empty">
                <p class="provider-card__note">
                  There are currently no UK providers to list for this option. We will update this page as regulation and availability change.
                </p>
                <a href="/contact/" class="btn btn--earth">Advertise future availability</a>
              </div>
            )}
          </article>
        ))}

        <div class="advertising-banner advertising-banner--midpage">
          <div class="advertising-banner__content">
            <p class="advertising-banner__eyebrow">For providers</p>
            <h2>Reach visitors already looking for sustainable funeral options</h2>
            <p>
              Featured listings, category sponsorships, and premium placements are available for relevant providers who
              want stronger visibility on this page.
            </p>
          </div>
          <div class="advertising-banner__actions">
            <a href="/contact/?topic=advertising" class="btn btn--primary">Advertise on this page</a>
            <a href="/advertise/" class="btn btn--outline advertising-banner__secondary">View advertising options</a>
          </div>
        </div>

        {bottomProviderCategories.map((option) => (
          <article class="provider-card">
            <div class="provider-card__header">
              <div>
                <p class="provider-card__eyebrow">Sustainable option</p>
                <h2>{option.title}</h2>
              </div>
              <span class="provider-card__status">{option.status}</span>
            </div>

            <p class="provider-card__summary">{option.summary}</p>
            <p class="provider-card__cost">{option.estimatedCost}</p>

            {option.providers.length > 0 ? (
              <div class="provider-card__providers">
                <h3>Providers and organisations</h3>
                <ul class="provider-list">
                  {option.providers.map((provider) => (
                    <li class="provider-list__item">
                      <div class="provider-list__topline">
                        <div class="provider-list__title-wrap">
                          {provider.sponsored && <span class="provider-list__badge">Sponsored</span>}
                          <a href={provider.href} target="_blank" rel="noopener noreferrer" class="provider-list__title">
                            {provider.name}
                          </a>
                        </div>
                        <a
                          href={provider.href}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="btn btn--primary provider-list__button"
                        >
                          Visit website
                        </a>
                      </div>
                      <p>{provider.note}</p>
                    </li>
                  ))}
                </ul>
              </div>
            ) : (
              <div class="provider-card__empty">
                <p class="provider-card__note">
                  There are currently no UK providers to list for this option. We will update this page as regulation and availability change.
                </p>
                <a href="/contact/" class="btn btn--earth">Advertise future availability</a>
              </div>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container container--narrow">
      <div class="campaign-banner">
        <div class="campaign-banner__content">
          <h2>Looking for human composting in the UK?</h2>
          <p>
            Terramation is not yet legally available here, but momentum is growing. Follow the campaign for updates on
            legislation, providers, and sustainable funeral reform.
          </p>
        </div>
        <a href="/contact/" class="btn btn--primary">Join the campaign</a>
      </div>
    </div>
  </section>

  <section class="section" style="padding-top:0;">
    <div class="container container--narrow">
      <div class="directory-cta">
        <h2>Want your brand featured here?</h2>
        <p>
          We can offer featured directory placement, category sponsorship, and exposure to readers actively comparing
          sustainable funeral choices in the UK.
        </p>
        <a href="/contact/" class="btn btn--earth">Enquire about advertising</a>
      </div>
    </div>
  </section>
</BaseLayout>
